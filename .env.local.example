# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your_anon_key_here>
# Service role key: Supabase → Settings → API → service_role (secret, server-only)
SUPABASE_SERVICE_ROLE_KEY=<your_service_role_key_here>

# ── Telegram Admin Bot ────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=<your_bot_token_here>
# Your chat_id from @userinfobot
TELEGRAM_ADMIN_CHAT_ID=<your_chat_id_here>
# Webhook secret (openssl rand -hex 32)
TELEGRAM_WEBHOOK_SECRET=<your_webhook_secret_here>

# ── Vercel Cron (generates daily subscription checks) ─────────
# Generate: openssl rand -hex 32
CRON_SECRET=<your_cron_secret_here>

# ── AI (chat widget / bio generator) ─────────────────────────
# Get from console.groq.com → API Keys
GROQ_API_KEY=<your_groq_api_key_here>

# ── vCard HMAC signing key (separate from service role key) ───
# Generate: openssl rand -hex 32
VCARD_SECRET=<your_vcard_secret_here>

# ── After deploy: register Telegram webhook ───────────────────
# curl "https://api.telegram.org/bot{TOKEN}/setWebhook?url=https://tapni.kz/api/telegram-bot&secret_token={TELEGRAM_WEBHOOK_SECRET}"
